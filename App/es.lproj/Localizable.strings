"help.title" = "Ayuda";
"help.header.title" = "Ayuda de %@";
"help.header.subtitle" = "Aprendizaje sin conexión, reproducción SCORM, descargas y seguimiento del progreso.";

"help.what_this_app_does.title" = "Qué hace esta aplicación";
"help.what_this_app_does.body" = "%@ Mobile le permite acceder al contenido de aprendizaje en la aplicación principal y abrir cursos SCORM descargados sin conexión.\n\nLa aplicación incluye un flujo nativo de aprendizaje sin conexión para:\n• acceso a cursos descargados\n• selección de lecciones\n• reproducción SCORM sin conexión\n• guardado local del progreso en su dispositivo";

"help.getting_started.title" = "Primeros pasos";
"help.getting_started.step1" = "Abra la aplicación e inicie sesión si es necesario.";
"help.getting_started.step2" = "Explore el contenido de aprendizaje disponible en la aplicación principal.";
"help.getting_started.step3" = "Descargue un curso SCORM si desea acceso sin conexión.";
"help.getting_started.step4" = "Abra el curso descargado desde el área de cursos sin conexión.";
"help.getting_started.step5" = "Elija una lección y comience a aprender.";

"help.using_offline_courses.title" = "Uso de cursos sin conexión";
"help.using_offline_courses.step1" = "Los paquetes SCORM descargados se almacenan localmente en su dispositivo.";
"help.using_offline_courses.step2" = "Los cursos sin conexión aparecen en la lista nativa de cursos sin conexión.";
"help.using_offline_courses.step3" = "Toque un curso para ver sus lecciones.";
"help.using_offline_courses.step4" = "Toque una lección para iniciar el reproductor SCORM.";
"help.using_offline_courses.step5" = "Una vez descargado por completo, el curso normalmente puede abrirse sin acceso a Internet.";

"help.progress_resume.title" = "Progreso y reanudación";
"help.progress_resume.step1" = "El progreso de su lección se guarda localmente mientras aprende.";
"help.progress_resume.step2" = "La aplicación almacena el progreso del alumno SCORM en almacenamiento SQLite nativo en el dispositivo.";
"help.progress_resume.step3" = "Cuando vuelva a abrir la misma lección más tarde, el estado guardado puede restaurarse según cómo ese paquete SCORM gestione los datos de reanudación.";
"help.progress_resume.step4" = "Si hay conectividad disponible, los flujos de trabajo de la aplicación también pueden admitir sincronización.";

"help.faq.title" = "Preguntas frecuentes";
"help.faq.q1" = "¿Necesito internet para reproducir un curso SCORM descargado?";
"help.faq.a1" = "No. Después de que un paquete SCORM se descargue y extraiga por completo, las lecciones pueden iniciarse localmente sin conexión.";
"help.faq.q2" = "¿Dónde se almacenan los archivos sin conexión?";
"help.faq.a2" = "Los archivos SCORM descargados se almacenan en el directorio Documents local de la aplicación en su dispositivo.";
"help.faq.q3" = "¿Se guarda mi progreso automáticamente?";
"help.faq.a3" = "Por lo general sí. El reproductor SCORM sin conexión guarda el progreso localmente mientras se ejecuta la lección y durante actualizaciones tipo commit de SCORM.";
"help.faq.q4" = "¿Por qué una lección no se abre correctamente?";
"help.faq.a4" = "Esto puede ocurrir si el paquete SCORM está incompleto, le falta metadatos de inicio o incluye contenido que depende de un comportamiento de navegador no compatible.";
"help.faq.q5" = "¿Funcionan las ventanas emergentes de lección?";
"help.faq.a5" = "Sí. El reproductor nativo admite ventanas emergentes usadas por algunos contenidos SCORM.";

"help.troubleshooting.title" = "Solución de problemas";
"help.troubleshooting.body" = "Si algo no funciona como se espera:\n\n• Confirme que el curso terminó de descargarse\n• Vuelva a abrir el curso y seleccione la lección otra vez\n• Asegúrese de haber abierto el curso sin conexión correcto\n• Pruebe el acceso en línea si el contenido depende de recursos remotos\n• Si el progreso parece incorrecto, vuelva a abrir la misma lección y verifique que seleccionó el curso y la lección esperados\n\nSi el problema continúa, capture el nombre del curso y de la lección antes de informarlo.";

"help.tips.title" = "Consejos útiles";
"help.tips.body" = "• Descargue cursos antes de perder conectividad\n• Abra los cursos importantes una vez después de descargarlos para confirmar que están listos\n• Use la lista de lecciones para iniciar exactamente la que necesita\n• Permanezca en la lección un momento antes de cerrarla para que el progreso tenga tiempo de guardarse";

