"help.title" = "Help";
"help.header.title" = "%@ Help";
"help.header.subtitle" = "Offline learning, SCORM playback, downloads, and progress tracking.";

"help.what_this_app_does.title" = "What this app does";
"help.what_this_app_does.body" = "%@ Mobile lets you access learning content in the main app and open downloaded SCORM courses offline.\n\nThe app includes a native offline learning flow for:\n• downloaded course access\n• lesson selection\n• offline SCORM playback\n• local progress saving on your device";

"help.getting_started.title" = "Getting Started";
"help.getting_started.step1" = "Open the app and sign in if needed.";
"help.getting_started.step2" = "Browse available learning content in the main app.";
"help.getting_started.step3" = "Download a SCORM course if you want offline access.";
"help.getting_started.step4" = "Open the downloaded course from the offline course area.";
"help.getting_started.step5" = "Choose a lesson and begin learning.";

"help.using_offline_courses.title" = "Using Offline Courses";
"help.using_offline_courses.step1" = "Downloaded SCORM packages are stored locally on your device.";
"help.using_offline_courses.step2" = "Offline courses appear in the native offline course list.";
"help.using_offline_courses.step3" = "Tap a course to view its lessons.";
"help.using_offline_courses.step4" = "Tap a lesson to launch the SCORM player.";
"help.using_offline_courses.step5" = "Once fully downloaded, the course can usually be opened without internet access.";

"help.progress_resume.title" = "Progress and Resume";
"help.progress_resume.step1" = "Your lesson progress is saved locally while you learn.";
"help.progress_resume.step2" = "The app stores SCORM learner progress in native SQLite storage on the device.";
"help.progress_resume.step3" = "When you reopen the same lesson later, saved state may be restored depending on how that SCORM package handles resume data.";
"help.progress_resume.step4" = "If connectivity is available, surrounding app workflows may also support sync behavior.";

"help.faq.title" = "Frequently Asked Questions";
"help.faq.q1" = "Do I need internet to play a downloaded SCORM course?";
"help.faq.a1" = "No. After a SCORM package is fully downloaded and extracted, lessons can be launched locally offline.";
"help.faq.q2" = "Where are offline files stored?";
"help.faq.a2" = "Downloaded SCORM files are stored in the app’s local Documents directory on your device.";
"help.faq.q3" = "Is my progress saved automatically?";
"help.faq.a3" = "Usually yes. The offline SCORM player saves progress locally as the lesson runs and during SCORM commit-style updates.";
"help.faq.q4" = "Why does a lesson fail to open correctly?";
"help.faq.a4" = "This can happen if the SCORM package is incomplete, missing launch metadata, or includes content that depends on unsupported browser behavior.";
"help.faq.q5" = "Do popup lesson windows work?";
"help.faq.a5" = "Yes. The native player supports popup windows used by some SCORM content.";

"help.troubleshooting.title" = "Troubleshooting";
"help.troubleshooting.body" = "If something is not working as expected:\n\n• Confirm the course completed downloading\n• Reopen the course and select the lesson again\n• Make sure you opened the correct offline course\n• Try online access if the content depends on remote resources\n• If progress looks incorrect, reopen the same lesson and verify you selected the expected course and lesson\n\nIf the issue continues, capture the course name and lesson name before reporting it.";

"help.tips.title" = "Helpful Tips";
"help.tips.body" = "• Download courses before you lose connectivity\n• Open important courses once after download to confirm they are ready\n• Use the lesson list to launch the exact lesson you need\n• Stay in the lesson briefly before closing so progress has time to save";

